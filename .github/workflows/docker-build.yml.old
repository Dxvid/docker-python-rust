name: Daily Docker Build

on:
  schedule:
    - cron: "27 16 * * 5"   # Build every friday
  workflow_dispatch:       # Manual trigger
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest

    strategy:
      matrix:
        variant:
          - name: tumbleweed
            path: opensuse/tumbleweed
            tag_suffix: opensuse-tumbleweed
          - name: leap
            path: opensuse/leap
            tag_suffix: opensuse-leap

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      # -----------------------------
      # Build image once (quiet mode)
      # -----------------------------
      - name: Build image (quiet)
        id: build
        run: |
          IMAGE_ID=$(docker build -q .)
          echo "IMAGE_ID=$IMAGE_ID" >> $GITHUB_OUTPUT

      # -----------------------------
      # Extract versions from image
      # -----------------------------
      - name: Extract versions
        id: versions
        run: |
          PY=$(docker run --rm ${{ steps.build.outputs.IMAGE_ID }} python3 --version | awk '{print $2}')
          RUST=$(docker run --rm ${{ steps.build.outputs.IMAGE_ID }} rustc --version | awk '{print $2}')
          OS=$(docker run --rm ${{ steps.build.outputs.IMAGE_ID }} bash -c "source /etc/os-release && echo \$VERSION_ID")

          echo "PYTHON_VERSION=$PY" >> $GITHUB_OUTPUT
          echo "RUST_VERSION=$RUST" >> $GITHUB_OUTPUT
          echo "OS_VERSION=$OS" >> $GITHUB_OUTPUT

      # -----------------------------
      # Generate date tag
      # -----------------------------
      - name: Set date tag
        id: date
        run: echo "DATE_TAG=$(date +'%Y%m%d')" >> $GITHUB_OUTPUT

      # -----------------------------
      # Log in to Docker Hub
      # -----------------------------
      - name: Log in to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKERHUB_USERNAME }}
          password: ${{ secrets.DOCKERHUB_TOKEN }}

      # -----------------------------
      # Build and push with all tags
      # -----------------------------
      - name: Build and push
        uses: docker/build-push-action@v5
        with:
          context: ${{ matrix.variant.path }}
          file: ${{ matrix.variant.path }}/Dockerfile
          push: true
          tags: |
            dxvid/python-rust:${{ matrix.variant.tag_suffix }}
            dxvid/python-rust:${{ matrix.variant.tag_suffix }}-${{ steps.versions.outputs.OS_VERSION }}
            dxvid/python-rust:${{ matrix.variant.tag_suffix }}-${{ steps.versions.outputs.OS_VERSION }}-py${{ steps.versions.outputs.PYTHON_VERSION }}-rust${{ steps.versions.outputs.RUST_VERSION }}
            dxvid/python-rust:${{ matrix.variant.tag_suffix }}-${{ steps.versions.outputs.OS_VERSION }}-py${{ steps.versions.outputs.PYTHON_VERSION }}-rust${{ steps.versions.outputs.RUST_VERSION }}-${{ steps.date.outputs.DATE_TAG }}
            dxvid/python-rust:${{ matrix.variant.tag_suffix }}-${{ github.sha }}
            dxvid/python-rust:${{ matrix.variant.tag_suffix }}-py${{ steps.versions.outputs.PYTHON_VERSION }}-rust${{ steps.versions.outputs.RUST_VERSION }}-${{ steps.date.outputs.DATE_TAG }}
            dxvid/python-rust:${{ matrix.variant.tag_suffix }}-py${{ steps.versions.outputs.PYTHON_VERSION }}-rust${{ steps.versions.outputs.RUST_VERSION }}
            ${{ matrix.variant.name == 'tumbleweed' && 'dxvid/python-rust:latest' || '' }}

      # -----------------------------
      # Enable build cache
      # -----------------------------
      - name: Cache Docker layers
        uses: actions/cache@v4
        with:
          path: /tmp/.buildx-cache
          key: ${{ runner.os }}-buildx-${{ github.sha }}
          restore-keys: |
            ${{ runner.os }}-buildx-
